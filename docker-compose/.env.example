# =============================================================================
# Checkpoint Production Environment Configuration
# Copy to .env and edit before running docker-compose.prod.yaml
# =============================================================================

# ---- Domain ----
# Base domain for the Checkpoint instance. Two subdomains are used:
#   checkpoint.<domain>     — Web UI and API
#   checkpoint-storage.<domain> — Storage server
CHECKPOINT_HOSTNAME=example.com

# ---- TLS Mode ----
# "none"   — HTTP only (no TLS, port 80)
# "acme"   — Automatic LetsEncrypt certificates (ports 80 + 443)
# "custom" — User-provided certificates (ports 80 + 443)
TLS_MODE=none

# ---- ACME / LetsEncrypt (only when TLS_MODE=acme) ----
# Email for LetsEncrypt registration and expiry notifications
ACME_EMAIL=

# Set to "true" to use LetsEncrypt staging environment (for testing)
ACME_STAGING=false

# ---- Custom Certificates (only when TLS_MODE=custom) ----
# Host directory containing fullchain.pem and privkey.pem
# This directory is bind-mounted read-only into the nginx container
CUSTOM_CERT_DIR=
