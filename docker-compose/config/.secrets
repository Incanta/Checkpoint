# Local secrets for the Checkpoint quickstart.
#
# The local secrets provider (see config/app/secrets.yaml and
# config/server/secrets.yaml) reads this file at /app/.secrets inside both
# containers. Format: one `key=value` per line.
#
# IMPORTANT: lines with an EMPTY value are ignored, so every secret that is
# actually referenced must have a non-empty value here or startup will fail.
# Generate strong random values before any real use, e.g.:
#   openssl rand -hex 32

# BetterAuth session/encryption secret (app).
betterauth_secret=changeme-betterauth-secret

# Shared JWT signing key for app <-> server storage tokens. It is shared simply
# by being referenced from this one file by both services.
storage_signing_key=changeme-storage-signing-key

# Postgres connection string for the app (whole-value secret). The password
# MUST match POSTGRES_PASSWORD in docker-compose.yaml.
database_url=postgresql://checkpoint:checkpoint@postgres:5432/checkpoint

# SMTP password - only needed if email is enabled in config/app/email.yaml.
email_smtp_password=

# Cloudflare R2 credentials - only needed when storage mode is "r2".
r2_access_key_id=
r2_secret_access_key=
r2_api_token=
