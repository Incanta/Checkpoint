{
  "name": "@checkpointvcs/root",
  "packageManager": "yarn@4.13.0",
  "workspaces": [
    "src/app",
    "src/core",
    "src/core/daemon",
    "src/core/server",
    "src/core/common",
    "src/clients/desktop",
    "src/tests"
  ],
  "scripts": {
    "postinstall": "node scripts/check-workspace-deps.js && cd src/app && yarn db:set-provider && yarn db:types && yarn db:migrate:dev",
    "check-workspace-deps": "node scripts/check-workspace-deps.js",
    "check-workspace-deps:fix": "node scripts/check-workspace-deps.js --fix",
    "lint": "eslint src/app src/core src/clients/desktop src/tests",
    "lint:fix": "eslint src/app src/core src/clients/desktop src/tests --fix",
    "build": "cd src/app && yarn build:lib && cd ../core && yarn build && cd ../tests && yarn typecheck",
    "dev": "node dev.js",
    "dev:agent": "node dev-agent.js",
    "desktop": "cd src/clients/desktop && yarn dev",
    "migrate": "node scripts/migrate.js",
    "test": "cd src/tests && yarn test",
    "test:service": "node scripts/test.js",
    "audit": "node scripts/audit.js"
  },
  "dependencies": {
    "@incanta/config": "^2.1.16",
    "@trpc/client": "^11.11.0",
    "@trpc/server": "^11.11.0",
    "njwt": "^2.0.1",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.2",
    "pretty-bytes": "^7.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "superjson": "^2.2.6",
    "zod": "^4.1.1"
  },
  "devDependencies": {
    "@eslint/compat": "^1.3.2",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.34.0",
    "@types/node": "^25.3.3",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript/native-preview": "^7.0.0-dev.20260304.1",
    "commander": "^14.0.3",
    "cross-env": "^10.0.0",
    "eslint": "^9.34.0",
    "eslint-config-next": "^15.2.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prefer-arrow": "^1.2.3",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^16.1.0",
    "next": "^16.2.6",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.27.0"
  },
  "resolutions": {
    "@incanta/config": "^2.1.10",
    "@trpc/client": "^11.11.0",
    "@trpc/server": "^11.11.0",
    "@types/node": "^25.3.3",
    "@typescript/native-preview": "^7.0.0-dev.20260304.1",
    "cross-env": "^10.0.0",
    "eslint": "^9.34.0",
    "njwt": "^2.0.1",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.2",
    "prettier": "^3.6.2",
    "pretty-bytes": "^7.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "superjson": "^2.2.6",
    "typescript": "^5.9.3",
    "zod": "^4.1.1",
    "@babel/core": "^7.29.7",
    "@ungap/structured-clone": "1.3.1",
    "brace-expansion@^2.0.1": "2.0.3",
    "brace-expansion@^2.0.2": "2.0.3",
    "brace-expansion@^5.0.2": "5.0.6",
    "dompurify": "^3.4.11",
    "effect": "^3.21.3",
    "esbuild": "^0.28.1",
    "fast-xml-parser": "^5.9.0",
    "form-data": "^4.0.6",
    "ip-address": "^10.2.0",
    "js-yaml": "^4.2.0",
    "picomatch@^4.0.2": "4.0.4",
    "picomatch@^4.0.3": "4.0.4",
    "postcss": "^8.5.10",
    "protobufjs": "7.6.4",
    "tar@^7.5.4": "^7.5.16"
  }
}
