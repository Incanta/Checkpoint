{
  "name": "@checkpointvcs/root",
  "packageManager": "yarn@4.13.0",
  "workspaces": [
    "src/app",
    "src/core",
    "src/core/daemon",
    "src/core/server",
    "src/core/common",
    "src/clients/desktop"
  ],
  "scripts": {
    "postinstall": "cd src/app && yarn db:types && yarn db:migrate:dev && cd src/longtail/addon && yarn install",
    "lint": "eslint src/app src/core src/clients/desktop",
    "lint:fix": "eslint src/app src/core src/clients/desktop --fix",
    "build": "cd src/longtail/addon && yarn build:ts && cd ../../app && yarn build:lib && cd ../core && yarn build",
    "dev": "node dev.js",
    "dev:agent": "node dev-agent.js",
    "desktop": "cd src/clients/desktop && yarn dev"
  },
  "dependencies": {
    "@incanta/config": "^2.1.10",
    "@trpc/client": "^11.11.0",
    "@trpc/server": "^11.11.0",
    "njwt": "^2.0.1",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.2",
    "pretty-bytes": "^7.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "superjson": "^2.2.6",
    "zod": "^4.1.1"
  },
  "devDependencies": {
    "@eslint/compat": "^1.3.2",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.34.0",
    "@types/node": "^25.3.3",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript/native-preview": "^7.0.0-dev.20260304.1",
    "cross-env": "^10.0.0",
    "eslint": "^9.34.0",
    "eslint-config-next": "^15.2.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prefer-arrow": "^1.2.3",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^16.1.0",
    "next": "^16.1.7",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.27.0"
  }
}
