{
  "name": "@checkpointvcs/core",
  "version": "1.0.0",
  "license": "(Elastic-2.0 OR AGPL-3.0)",
  "private": true,
  "workspaces": [
    "client",
    "daemon",
    "server",
    "common"
  ],
  "scripts": {
    "build": "cd server && yarn build && cd ../daemon && yarn build",
    "lint": "eslint .",
    "cli": "NODE_CONFIG_DIR=client/config bun run client/src/bin.ts",
    "package": "bun package.ts",
    "server": "cd server && yarn start",
    "daemon": "cd daemon && yarn start"
  },
  "peerDependencies": {
    "@incanta/config": "*",
    "@trpc/client": "*",
    "@trpc/server": "*",
    "njwt": "*",
    "pino": "*",
    "pino-pretty": "*",
    "superjson": "*"
  },
  "dependencies": {
    "@checkpointvcs/app": "workspace:*",
    "async-sema": "^3.1.1",
    "inquirer": "^12.5.0",
    "lodash.merge": "^4.6.2",
    "open": "^10.1.0",
    "yup": "^1.6.1"
  },
  "devDependencies": {
    "@types/lodash.merge": "^4.6.9",
    "tmp-promise": "^3.0.3"
  }
}
