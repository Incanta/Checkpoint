{
  "name": "@checkpointvcs/core",
  "version": "0.4.0",
  "license": "(Elastic-2.0 OR AGPL-3.0)",
  "private": true,
  "workspaces": [
    "client",
    "daemon",
    "server",
    "license-manager",
    "common"
  ],
  "scripts": {
    "build": "cd server && yarn build && cd ../daemon && yarn build",
    "lint": "eslint .",
    "cli": "NODE_CONFIG_DIR=client/config bun run client/src/bin.ts",
    "package": "bun package.ts",
    "server": "cd server && yarn start",
    "daemon": "cd daemon && yarn start",
    "license-manager": "cd license-manager && yarn start"
  },
  "peerDependencies": {
    "@incanta/config": "^2.1.16",
    "@trpc/client": "^11.11.0",
    "@trpc/server": "^11.11.0",
    "njwt": "^2.0.1",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.2",
    "superjson": "^2.2.6"
  },
  "dependencies": {
    "@checkpointvcs/app": "workspace:*",
    "async-sema": "^3.1.1",
    "inquirer": "^12.5.0",
    "lodash.merge": "^4.6.2",
    "open": "^10.1.0",
    "yup": "^1.6.1"
  },
  "devDependencies": {
    "@types/lodash.merge": "^4.6.9",
    "eslint": "^9.34.0",
    "tmp-promise": "^3.0.3"
  }
}
