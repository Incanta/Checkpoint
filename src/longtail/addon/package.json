{
  "name": "@checkpointvcs/longtail-addon",
  "version": "1.0.17",
  "description": "Node.js N-API addon for the Longtail C++ wrapper",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "(Elastic-2.0 OR AGPL-3.0)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Incanta/Checkpoint.git",
    "directory": "src/longtail/addon"
  },
  "files": [
    "dist",
    "prebuilds"
  ],
  "packageManager": "yarn@4.13.0",
  "scripts": {
    "build:native": "cmake-js build --config Release",
    "build:native:msvc": "cmd /c build-msvc.bat",
    "build:native:msvc:debug": "cmd /c build-msvc.bat debug",
    "build:ts": "tsc",
    "build": "yarn run build:native && yarn run build:ts",
    "build:msvc": "yarn run build:native:msvc && yarn run build:ts",
    "clean": "cmake-js clean"
  },
  "devDependencies": {
    "@types/node": "*",
    "cmake-js": "^8.0.0",
    "node-addon-api": "^8.3.1",
    "typescript": "^5.9.3"
  }
}
