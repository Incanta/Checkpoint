{
  "name": "@checkpointvcs/metrics",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Incanta-hosted telemetry ingestion + usage dashboard for self-hosted Checkpoint instances",
  "scripts": {
    "dev": "next dev --turbo -p 13003",
    "build": "next build",
    "start": "next start -p 13003",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate --schema=prisma/schema.prisma",
    "db:push": "prisma db push --schema=prisma/schema.prisma",
    "postinstall": "prisma generate --schema=prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "chart.js": "^4.5.1",
    "next": "^16.2.9",
    "react": "^19.0.0",
    "react-chartjs-2": "^5.3.1",
    "zod": "^4.1.1"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "prisma": "^6.5.0",
    "typescript": "^5.9.3"
  }
}
