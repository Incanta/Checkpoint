{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    // The harness imports app modules via `~/*` (resolved to ../app/src/*).
    // Without `allowJs`, tsc can't see env.js along that chain; without
    // dropping `rootDir`, every traversed app file errors as "outside
    // rootDir". `rootDir` and `outDir` are no-ops anyway with `noEmit`.
    "allowJs": true,
    "types": ["vitest/globals", "node"],
    "paths": {
      "~/*": ["../app/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
