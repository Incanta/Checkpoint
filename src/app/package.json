{
  "name": "@checkpointvcs/app",
  "version": "0.1.0",
  "minDesktopVersion": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/lib/trpc-client.js",
  "types": "dist/lib/trpc-client.d.ts",
  "exports": {
    ".": {
      "import": "./dist/lib/trpc-client.js",
      "types": "./dist/lib/trpc-client.d.ts"
    }
  },
  "scripts": {
    "build": "next build",
    "build:lib": "tsgo --project tsconfig.lib.json && node scripts/resolve-prisma-enums.mjs",
    "check": "eslint . && tsgo --noEmit",
    "db:set-provider": "yarn db:set-provider:sqlite",
    "db:set-provider:sqlite": "cross-env DB_PROVIDER=sqlite node scripts/set-db-provider.mjs",
    "db:set-provider:postgresql": "cross-env DB_PROVIDER=postgresql node scripts/set-db-provider.mjs",
    "db:types": "prisma generate",
    "db:migrate:dev": "config-env --env=default prisma migrate dev",
    "db:migrate:deploy": "config-env --env=default prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:migrate-to-postgres": "node scripts/migrate-sqlite-to-postgres.mjs",
    "dev": "config-env --env=default next dev --turbo",
    "dev:test": "config-env --env=test next dev --turbo",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "postinstall": "yarn db:set-provider && prisma generate",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "next build && next start",
    "start": "config-env --env=default next start",
    "typecheck": "tsgo --noEmit"
  },
  "peerDependencies": {
    "@incanta/config": "*",
    "@trpc/client": "*",
    "@trpc/server": "*",
    "njwt": "*",
    "pretty-bytes": "*",
    "react": "*",
    "react-dom": "*",
    "superjson": "*",
    "zod": "*"
  },
  "dependencies": {
    "@better-auth/prisma-adapter": "^1.5.3",
    "@checkpointvcs/longtail-addon": "^1.0.15",
    "@prisma/client": "^6.5.0",
    "@t3-oss/env-nextjs": "^0.12.0",
    "@tanstack/react-query": "^5.69.0",
    "@trpc/react-query": "^11.8.1",
    "better-auth": "^1.5.3",
    "cross-env": "*",
    "next": "^16.1.7",
    "nodemailer": "^8.0.4",
    "server-only": "^0.0.1",
    "shiki": "^3.0.0"
  },
  "devDependencies": {
    "@incanta/config": "*",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "*",
    "@types/nodemailer": "^7.0.11",
    "@typescript/native-preview": "*",
    "eslint": "*",
    "javascript-obfuscator": "^5.4.1",
    "postcss": "^8.5.3",
    "prettier": "*",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "prisma": "^6.5.0",
    "tailwindcss": "^4.1.18"
  },
  "ct3aMetadata": {
    "initVersion": "7.39.3"
  },
  "prisma": {
    "schema": "prisma/"
  }
}
