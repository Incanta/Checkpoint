// Don't forget to tell Prisma about your edits to this file using
// `yarn rw prisma migrate dev` or `yarn rw prisma db push`.
// `migrate` is like committing while `push` is for prototyping.
// Read more about both here:
// https://www.prisma.io/docs/orm/prisma-migrate

// NOTE: The datasource block lives in prisma/datasource.prisma (generated from
// config, gitignored). Run `npm run db:set-provider` to regenerate it.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = "native"
}

model User {
  id       String  @id @default(cuid())
  name     String?
  username String?

  email         String  @unique
  emailVerified Boolean @default(false)

  image String?

  checkpointAdmin Boolean @default(false)

  orgs              OrgUser[]
  specificRepoRoles RepoRole[]
  changelists       Changelist[]
  workspaces        Workspace[]
  apiTokens         ApiToken[]
  createdBranches   Branch[]          @relation("BranchCreator")
  activity          OrgUserActivity[]

  pullRequests     PullRequest[]
  prComments       PullRequestComment[]
  prReviews        PullRequestReview[]
  mergePermissions MergePermission[]
  shelves          Shelf[]

  issues           Issue[]
  issueComments    IssueComment[]
  issueAssignments IssueAssignee[]

  notifications      Notification[]            @relation("NotificationRecipient")
  actedNotifications Notification[]            @relation("NotificationActor")
  issueSubscriptions IssueSubscription[]
  prSubscriptions    PullRequestSubscription[]

  // Auth
  accounts Account[]
  sessions Session[]

  emailPreferences EmailPreferences?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmailPreferences {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Per-category toggles (all default to true)
  accountSecurity Boolean @default(true)
  orgActivity     Boolean @default(true)
  repoActivity    Boolean @default(true)
  mentions        Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum RepoAccess {
  NONE
  READ
  WRITE
  ADMIN
}

enum OrgRole {
  MEMBER
  BILLING
  ADMIN
}

model Org {
  id        String    @id @default(cuid())
  deletedAt DateTime?
  deletedBy String?

  name String @unique

  defaultRepoAccess     RepoAccess @default(WRITE)
  defaultCanCreateRepos Boolean    @default(true)

  binaryExtensions String @default("")

  subscriptionTier LicenseTier @default(BASIC)

  users      OrgUser[]
  repos      Repo[]
  workspaces Workspace[]
  activity   OrgUserActivity[]
  license    License?
}

model OrgUser {
  id             String  @id @default(cuid())
  role           OrgRole @default(MEMBER)
  canCreateRepos Boolean @default(true)

  org   Org    @relation(fields: [orgId], references: [id])
  orgId String

  user   User   @relation(fields: [userId], references: [id])
  userId String

  @@unique([orgId, userId])
}

model Repo {
  id        String    @id @default(cuid())
  deletedAt DateTime?
  deletedBy String?

  name String

  public Boolean @default(false)

  r2BucketName String?

  org   Org    @relation(fields: [orgId], references: [id])
  orgId String

  additionalRoles RepoRole[]

  requiredReviews      Int     @default(0)
  mergePermissionsSame Boolean @default(true)

  files            File[]
  changelists      Changelist[]
  branches         Branch[]          @relation("RepoBranch")
  labels           ChangelistLabel[]
  workspaces       Workspace[]
  fileCheckouts    FileCheckout[]
  pullRequests     PullRequest[]
  mergePermissions MergePermission[]
  shelves          Shelf[]
  issues           Issue[]
  issueLabels      IssueLabel[]

  @@unique([orgId, name])
}

model RepoRole {
  id String @id @default(cuid())

  access RepoAccess

  repo   Repo   @relation(fields: [repoId], references: [id])
  repoId String

  user   User   @relation(fields: [userId], references: [id])
  userId String

  @@unique([repoId, userId])
}

enum BranchType {
  MAINLINE
  RELEASE
  FEATURE
}

model Branch {
  id String @id @default(cuid())

  repo   Repo   @relation("RepoBranch", fields: [repoId], references: [id])
  repoId String

  name       String
  headNumber Int

  isDefault Boolean @default(false)

  type       BranchType @default(MAINLINE)
  archivedAt DateTime?

  // Parent branch relationship (feature→mainline/release, release→mainline)
  parentBranch     Branch?  @relation("BranchParent", fields: [repoId, parentBranchName], references: [repoId, name])
  parentBranchName String?
  childBranches    Branch[] @relation("BranchParent")

  // Creator tracking for permission checks
  createdBy   User?   @relation("BranchCreator", fields: [createdById], references: [id])
  createdById String?

  @@unique([repoId, name])
}

model Changelist {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  number       Int
  message      String
  versionIndex String
  stateTree    Json

  // Artifact overlay (populated by CI after submit)
  artifactVersionIndex String?
  artifactStateTree    Json?

  repo   Repo   @relation(fields: [repoId], references: [id])
  repoId String

  user   User?   @relation(fields: [userId], references: [id])
  userId String?

  parent       Changelist?  @relation("ChangelistToParent", fields: [repoId, parentNumber], references: [repoId, number])
  children     Changelist[] @relation("ChangelistToParent")
  parentNumber Int? // NOTE: Merges are handled via forced squashing

  fileChanges FileChange[]
  labels      ChangelistLabel[]
  artifacts   ArtifactFile[]

  @@unique([repoId, number])
}

model ChangelistLabel {
  id String @id @default(cuid())

  name String

  changelist Changelist @relation(fields: [repoId, number], references: [repoId, number])
  repoId     String
  number     Int

  repo Repo @relation(fields: [repoId], references: [id])

  @@unique([repoId, name])
}

enum FileChangeType {
  ADD
  DELETE
  MODIFY
}

model FileChange {
  id String @id @default(cuid())

  file   File   @relation(fields: [fileId], references: [id])
  fileId String

  changelist       Changelist @relation(fields: [repoId, changelistNumber], references: [repoId, number])
  repoId           String
  changelistNumber Int

  type    FileChangeType
  oldPath String?
}

model ArtifactFile {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  changelist       Changelist @relation(fields: [repoId, changelistNumber], references: [repoId, number])
  repoId           String
  changelistNumber Int

  file   File   @relation(fields: [fileId], references: [id])
  fileId String

  size BigInt

  @@unique([repoId, changelistNumber, fileId])
  @@index([repoId, changelistNumber])
}

model File {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  path String

  repo   Repo   @relation(fields: [repoId], references: [id])
  repoId String

  changes       FileChange[]
  checkouts     FileCheckout[]
  shelfChanges  ShelfFileChange[]
  artifactFiles ArtifactFile[]

  @@index([repoId])
}

model FileCheckout {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  removedAt DateTime?

  locked Boolean @default(false)

  fileId String
  file   File   @relation(fields: [fileId], references: [id])

  repoId String
  repo   Repo   @relation(fields: [repoId], references: [id])

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
}

model Workspace {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  name String

  userId String
  user   User   @relation(fields: [userId], references: [id])

  repoId String
  repo   Repo   @relation(fields: [repoId], references: [id])

  orgId String
  org   Org    @relation(fields: [orgId], references: [id])

  fileCheckouts FileCheckout[]
}

model ApiToken {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  expiresAt DateTime?

  name       String
  token      String  @unique
  deviceCode String? @unique

  userId String
  user   User   @relation(fields: [userId], references: [id])
}

model OrgUserActivity {
  id String @id @default(cuid())

  user   User   @relation(fields: [userId], references: [id])
  userId String

  org   Org    @relation(fields: [orgId], references: [id])
  orgId String

  year  Int
  month Int // 1-12

  writeCount  Int       @default(0)
  readCount   Int       @default(0)
  lastWriteAt DateTime?
  lastReadAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, orgId, year, month])
  @@index([orgId, year, month])
}

enum PullRequestStatus {
  OPEN
  MERGED
  CLOSED
}

model PullRequest {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  number Int

  title       String
  description String @default("")

  status   PullRequestStatus @default(OPEN)
  mergedAt DateTime?
  closedAt DateTime?

  sourceBranchName String
  targetBranchName String

  repo   Repo   @relation(fields: [repoId], references: [id])
  repoId String

  author   User   @relation(fields: [authorId], references: [id])
  authorId String

  comments      PullRequestComment[]
  reviews       PullRequestReview[]
  subscriptions PullRequestSubscription[]
  notifications Notification[]

  @@unique([repoId, number])
  @@index([repoId, status])
}

model PullRequestComment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  body String

  pullRequest   PullRequest @relation(fields: [pullRequestId], references: [id], onDelete: Cascade)
  pullRequestId String

  author   User   @relation(fields: [authorId], references: [id])
  authorId String
}

enum ReviewState {
  PENDING
  REQUEST_CHANGES
  APPROVED
}

model PullRequestReview {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  state ReviewState @default(PENDING)

  pullRequest   PullRequest @relation(fields: [pullRequestId], references: [id], onDelete: Cascade)
  pullRequestId String

  reviewer   User   @relation(fields: [reviewerId], references: [id])
  reviewerId String

  @@unique([pullRequestId, reviewerId])
}

enum LicenseTier {
  BASIC
  PRO
  STUDIO
  INCANTA
}

model License {
  id         String      @id @default(cuid())
  key        String      @unique
  secretHash String
  tier       LicenseTier @default(BASIC)
  active     Boolean     @default(true)

  // Cloud: links to an org on this instance
  orgId String? @unique
  org   Org?    @relation(fields: [orgId], references: [id])

  // Self-hosted: metadata about the remote instance
  instanceName String?
  instanceUrl  String?

  lastReportAt DateTime?

  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  usageReports LicenseUsageReport[]
}

model LicenseUsageReport {
  id        String  @id @default(cuid())
  licenseId String
  license   License @relation(fields: [licenseId], references: [id], onDelete: Cascade)
  year      Int
  month     Int
  awuCount  Int
  aruCount  Int

  reportedAt DateTime @default(now())

  @@unique([licenseId, year, month])
}

enum MergePermissionType {
  MAINLINE
  RELEASE
}

model MergePermission {
  id String @id @default(cuid())

  type MergePermissionType

  repo   Repo   @relation(fields: [repoId], references: [id], onDelete: Cascade)
  repoId String

  user   User   @relation(fields: [userId], references: [id])
  userId String

  @@unique([repoId, userId, type])
}

// Shelves — mutable dangling changelists (Pro+)

enum ShelfStatus {
  ACTIVE
  SUBMITTED
  DELETED
}

model Shelf {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name        String
  description String @default("")

  repo   Repo   @relation(fields: [repoId], references: [id])
  repoId String

  author   User   @relation(fields: [authorId], references: [id])
  authorId String

  // Current longtail version index (all-inclusive of shelf files)
  versionIndex String
  stateTree    Json // {fileId → changelistNumber}

  // Dangling changelist number (from repo sequence, not on any branch)
  changelistNumber Int

  status ShelfStatus @default(ACTIVE)

  // Submitted metadata
  submittedToBranch String?
  submittedAt       DateTime?

  fileChanges ShelfFileChange[]

  @@unique([repoId, name])
  @@index([repoId, status])
}

model ShelfFileChange {
  id String @id @default(cuid())

  shelf   Shelf  @relation(fields: [shelfId], references: [id], onDelete: Cascade)
  shelfId String

  file   File   @relation(fields: [fileId], references: [id])
  fileId String

  type String // ADD, MODIFY

  @@unique([shelfId, fileId])
}

// ── Issues ──────────────────────────────────────────────────────

enum IssueStatus {
  OPEN
  CLOSED
}

model Issue {
  id     String @id @default(cuid())
  number Int
  title  String
  body   String @default("")

  status   IssueStatus @default(OPEN)
  closedAt DateTime?

  repo   Repo   @relation(fields: [repoId], references: [id])
  repoId String

  author   User   @relation(fields: [authorId], references: [id])
  authorId String

  comments      IssueComment[]
  labels        IssueLabelLink[]
  assignees     IssueAssignee[]
  subscriptions IssueSubscription[]
  notifications Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([repoId, number])
  @@index([repoId, status])
}

model IssueComment {
  id   String @id @default(cuid())
  body String

  issue   Issue  @relation(fields: [issueId], references: [id], onDelete: Cascade)
  issueId String

  author   User   @relation(fields: [authorId], references: [id])
  authorId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model IssueLabel {
  id    String @id @default(cuid())
  name  String
  color String @default("#6366f1")

  repo   Repo   @relation(fields: [repoId], references: [id])
  repoId String

  issues IssueLabelLink[]

  @@unique([repoId, name])
}

model IssueLabelLink {
  id String @id @default(cuid())

  issue   Issue  @relation(fields: [issueId], references: [id], onDelete: Cascade)
  issueId String

  label   IssueLabel @relation(fields: [labelId], references: [id], onDelete: Cascade)
  labelId String

  @@unique([issueId, labelId])
}

model IssueAssignee {
  id String @id @default(cuid())

  issue   Issue  @relation(fields: [issueId], references: [id], onDelete: Cascade)
  issueId String

  user   User   @relation(fields: [userId], references: [id])
  userId String

  @@unique([issueId, userId])
}

// ── Notifications & Subscriptions ────────────────────────────────

model Notification {
  id    String @id @default(cuid())
  type  String // e.g. "issue_comment", "issue_mention", "pr_review", etc.
  title String
  body  String @default("")
  link  String // relative URL to navigate to

  read Boolean @default(false)

  user   User   @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  userId String

  actor   User?   @relation("NotificationActor", fields: [actorId], references: [id])
  actorId String?

  issue   Issue?  @relation(fields: [issueId], references: [id], onDelete: Cascade)
  issueId String?

  pullRequest   PullRequest? @relation(fields: [pullRequestId], references: [id], onDelete: Cascade)
  pullRequestId String?

  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}

model IssueSubscription {
  id String @id @default(cuid())

  issue   Issue  @relation(fields: [issueId], references: [id], onDelete: Cascade)
  issueId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  createdAt DateTime @default(now())

  @@unique([issueId, userId])
}

model PullRequestSubscription {
  id String @id @default(cuid())

  pullRequest   PullRequest @relation(fields: [pullRequestId], references: [id], onDelete: Cascade)
  pullRequestId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  createdAt DateTime @default(now())

  @@unique([pullRequestId, userId])
}

// better-auth models

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt
}
